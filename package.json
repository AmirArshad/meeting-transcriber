{
  "name": "avanevis",
  "version": "2.4.3",
  "description": "AI-powered meeting transcription with desktop audio capture",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "npm run test:syntax && npm run test:js",
    "test:js": "node --test",
    "test:python": "node scripts/run-python-tests.js",
    "test:all": "npm test && npm run test:python",
    "test:syntax": "node scripts/check-js-syntax.js",
    "clean": "node scripts/clean-dist.js",
    "prepare-build": "npm run clean && node build/prepare-resources.js",
    "legal:sbom": "node scripts/generate-python-sbom.js",
    "legal:release-assets": "node scripts/stage-release-legal-assets.js",
    "build": "npm run prepare-build && electron-builder build --win --publish never",
    "build:dir": "npm run prepare-build && electron-builder build --win --dir",
    "build:mac": "npm run prepare-build && electron-builder build --mac --publish never",
    "build:mac:dir": "npm run prepare-build && electron-builder build --mac --dir",
    "verify:mac:packaged": "bash scripts/verify-macos-packaged-app.sh"
  },
  "keywords": [
    "transcription",
    "whisper",
    "meeting",
    "audio"
  ],
  "author": "AvaNevis",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.avanevis.app",
    "productName": "AvaNevis",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "binaries": [
        "Contents/Resources/bin/audiocapture-helper",
        "Contents/Resources/ffmpeg/ffmpeg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "AvaNevis needs microphone access to record your voice during meetings.",
        "NSAudioCaptureUsageDescription": "AvaNevis needs system audio access to capture desktop audio locally for meeting transcription.",
        "NSAppleMusicUsageDescription": "AvaNevis does not access your music library.",
        "NSCameraUsageDescription": "AvaNevis does not use your camera.",
        "NSScreenCaptureUsageDescription": "AvaNevis needs screen recording permission to capture system audio (desktop audio) using ScreenCaptureKit. No screen video is recorded, only audio."
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AvaNevis",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "license": "LICENSE.txt",
      "differentialPackage": true,
      "warningsAsErrors": false,
      "displayLanguageSelector": false
    },
    "compression": "store",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "electronLanguages": [
      "en-US",
      "en",
      "es",
      "fr",
      "de",
      "zh-CN",
      "ja"
    ],
    "files": [
      "src/**/*",
      "THIRD_PARTY_NOTICES.md",
      "legal/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "extraResources": [
      {
        "from": "build/resources/python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/resources/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*.py"
        ]
      },
      {
        "from": "build/resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/iconTemplate.png",
        "to": "iconTemplate.png"
      },
      {
        "from": "build/iconTemplate@2x.png",
        "to": "iconTemplate@2x.png"
      },
      {
        "from": "build/resources/legal",
        "to": "legal",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    }
  }
}
